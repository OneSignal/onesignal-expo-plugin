{
  "name": "onesignal-expo-plugin",
  "version": "2.1.0",
  "description": "Some Changez",
  "main": "./app.plugin.js",
  "files": [
    "build",
    "app.plugin.js"
  ],
  "scripts": {
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "build": "bun run lint && rm -rf build && tsc && cp -a src/support/serviceExtensionFiles build/support/",
    "format:check": "prettier --check \"**/*.{ts,tsx}\" --ignore-path .prettierignore",
    "format:fix": "prettier --write \"**/*.{ts,tsx}\" --ignore-path .prettierignore",
    "lint": "oxlint src examples && bun run format:check",
    "lint:fix": "oxlint src examples --fix && bun run format:fix"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/OneSignal/onesignal-expo-plugin.git"
  },
  "keywords": [
    "expo",
    "onesignal",
    "push",
    "notifications",
    "EAS"
  ],
  "author": "rgomezp",
  "contributors": [
    "Karen Grigoryan",
    "Rodrigo Gomez-Palacio",
    "Charlie Cruzan",
    "Wojciech Kozyra",
    "Brian Smith"
  ],
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/OneSignal/onesignal-expo-plugin/issues"
  },
  "homepage": "https://github.com/OneSignal/onesignal-expo-plugin#readme",
  "devDependencies": {
    "@types/bun": "^1.3.9",
    "expo-module-scripts": "^5.0.8",
    "oxlint": "^1.43.0",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "react-native-onesignal": ">=5.0.0"
  },
  "dependencies": {
    "@expo/image-utils": "^0.8.8"
  }
}
